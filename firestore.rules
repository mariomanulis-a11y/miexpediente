rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Usuarios ────────────────────────────────────────────
    match /usuarios/{uid} {
      allow read: if request.auth.uid == uid;
      allow write: if request.auth.uid == uid;
    }

    // ── Expedientes ─────────────────────────────────────────
    match /expedientes/{expId} {
      // El profesional propietario puede leer y escribir
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'profesional' &&
        resource.data.profesionalId == request.auth.uid;

      // El cliente solo puede leer su propio expediente
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'cliente' &&
        resource.data.clienteId ==
          get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.clienteId;

      // Crear: solo profesionales
      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'profesional' &&
        request.resource.data.profesionalId == request.auth.uid;
    }

    // ── Clientes ────────────────────────────────────────────
    match /clientes/{cliId} {
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'profesional' &&
        resource.data.profesionalId == request.auth.uid;

      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'profesional' &&
        request.resource.data.profesionalId == request.auth.uid;
    }
  }
}
