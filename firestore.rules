rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────
    function isLoggedIn() {
      return request.auth != null;
    }
    function getUser() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }
    function isProfesional() {
      return isLoggedIn() && getUser().rol == 'profesional';
    }
    function isCliente() {
      return isLoggedIn() && getUser().rol == 'cliente';
    }
    function isOwnerCliente(expData) {
      return isCliente() && expData.clienteId == request.auth.uid;
    }
    // Bootstrap: usuario autenticado puede crear su propio doc solo si no existe aún
    function canBootstrap(uid) {
      return isLoggedIn() && request.auth.uid == uid &&
             !exists(/databases/$(database)/documents/usuarios/$(uid));
    }

    // ── Usuarios ──────────────────────────────────────────────
    match /usuarios/{uid} {
      allow read:   if isLoggedIn() && (request.auth.uid == uid || isProfesional());
      allow create: if isProfesional() || canBootstrap(uid);
      allow update: if isProfesional() || request.auth.uid == uid;
      allow delete: if isProfesional();
    }

    // ── Expedientes ───────────────────────────────────────────
    match /expedientes/{expId} {
      allow read:   if isProfesional() || isOwnerCliente(resource.data);
      allow create: if isProfesional();
      allow update: if isProfesional();
      allow delete: if isProfesional();
    }
  }
}
